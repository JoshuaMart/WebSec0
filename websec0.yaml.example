# WebSec0 configuration — example
# Resolution order: $WEBSEC0_CONFIG → ./websec0.yaml → /etc/websec0/websec0.yaml
# See SPECIFICATIONS.md §7 for the authoritative reference.

server:
  listen: "0.0.0.0:8080"
  trusted_proxies: []           # CIDRs allowed to set X-Forwarded-For

scan:
  timeout: 30s                  # global per-scan budget
  parallel_probes: true
  follow_redirects: true        # for header probing
  max_redirects: 3

security:
  # Public instance: keep both `false`. Self-hosted on a private network:
  # set to `true` to scan internal targets and/or non-443 ports.
  allow_private_targets: false
  allow_custom_ports: false
  allowed_schemes: ["https"]    # `http` will become an opt-in in v1.1
  extra_blocked_cidrs: []       # e.g. ["10.20.0.0/16", "2001:db8::/32"]

cache:
  ttl: 24h                      # how long a scan ID remains retrievable
  max_entries: 1000             # LRU bound

history:
  enabled: true                 # exposes the "Recent scans" strip on the landing
  retention: 7d                 # scans listed publicly are purged after this
  rate_limit:
    per_ip: "10/hour"
    per_host: "1/minute"        # avoid hammering a target

frontend:
  enabled: true                 # serve the embedded UI at /
  base_path: "/"
  # Raw HTML spliced before </head> in every served page. Intended for
  # analytics on a public deployment (Umami, Plausible, …). Trusted: not
  # escaped. Empty = no injection (default, what self-hosters get).
  head_inject: ""
  # head_inject: |
  #   <script defer src="https://umami.example.com/script.js"
  #           data-website-id="xxxx-xxxx"></script>
  # Optional directory whose tree mirrors URL paths. Files inside take
  # precedence over anything embedded in the binary:
  #
  #   <dir>/.well-known/security.txt → /.well-known/security.txt  (RFC 9116)
  #   <dir>/robots.txt               → /robots.txt
  #   <dir>/humans.txt               → /humans.txt
  #   <dir>/ads.txt                  → /ads.txt
  #   <dir>/sitemap.xml              → /sitemap.xml
  #
  # Anything under .well-known/ is allowed; at the root only the four
  # files above are honoured (so a misconfigured overlay cannot hijack
  # the SPA shell). Paths absent from the overlay fall back to the
  # embedded fs. Mount it read-only in your container:
  #
  #   volumes:
  #     - ./public:/etc/websec0/public:ro
  static_overlay_dir: ""

telemetry:
  anonymous_stats: false        # if true, send scan counts (no hostnames) to a stats endpoint

log:
  # When true, surfaces a per-handshake diagnostic line on stderr:
  #
  #   level=DEBUG msg=handshake seq=42 host=example.com port=443
  #     min_version="TLS 1.1" max_version="TLS 1.1" cipher_pinned=false
  #     duration_ms=3001 err_kind=timeout err_msg="i/o timeout"
  #
  # Useful when a target stops responding mid-scan (typically a WAF
  # blackholing the scanner after a legacy ClientHello) and you need to
  # correlate the bascule with a specific protocol/cipher pair. The volume
  # is ~450 lines per scan worst case, so keep this off in production.
  debug_handshakes: false
