---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'WebSec0',
  description = 'Passive web security scanner — TLS, headers, DNS, email security and more.',
} = Astro.props;

const pageTitle = title === 'WebSec0' ? title : `${title} — WebSec0`;
---
<!doctype html>
<html lang="en" class="h-full scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body class="flex flex-col min-h-full">
    <slot />

    <script>
      // Operator-facing instance metadata (contact email, User-Agent string).
      // Populated once at boot from GET /api/v1/instance so self-hosters can
      // override these values via config.yaml without rebuilding the frontend.
      // Default placeholder text stays visible if JS is disabled or the
      // endpoint is unreachable.
      document.addEventListener('alpine:init', () => {
        Alpine.store('instance', {
          contactEmail: 'operator@example.invalid',
          userAgent: 'WebSec0 (configure scanner.user_agent in config.yaml)',
          async load() {
            try {
              const res = await fetch('/api/v1/instance');
              if (!res.ok) return;
              const data = await res.json();
              if (data.contact_email) this.contactEmail = data.contact_email;
              if (data.user_agent) this.userAgent = data.user_agent;
            } catch { /* keep placeholders */ }
          },
        });
        Alpine.store('instance').load();
      });
    </script>
  </body>
</html>
