---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>WebSec0 — security configuration scanner</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <div class="brand">
          <svg class="brand-mark" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
            <circle cx="8" cy="8" r="6.5" fill="none" stroke="var(--good)" stroke-width="1.5" />
            <circle cx="8" cy="8" r="3.5" fill="var(--ink)" />
          </svg>
          websec0
        </div>
        <div style="flex:1"></div>
        <div class="nav-links">
          <a href="/api/v1/checks">Checks</a>
          <a href="https://github.com/JoshuaMart/websec0" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </nav>

    <main>
      <section class="hero">
        <div class="eyebrow">
          <span class="dot"></span>
          <span>passive TLS + HTTP headers scanner</span>
        </div>
        <h1>
          Audit any site's<br />
          <span class="accent">security config</span> in seconds.
        </h1>
        <p class="lede">
          WebSec0 inspects TLS configuration, HTTP security headers and custom
          checks (security.txt, robots.txt). Two grades, actionable findings,
          copy-paste fixes — all from a single hostname.
        </p>

        <form class="scan-form" id="scanForm" autocomplete="off">
          <span class="prefix">https://</span>
          <input
            id="hostInput"
            type="text"
            placeholder="example.com"
            spellcheck="false"
            autocapitalize="off"
            required
          />
          <button type="submit" class="btn btn-primary">Run scan →</button>
        </form>

        <label class="opt-public">
          <input type="checkbox" id="listInHistory" />
          <span>List in public history</span>
        </label>

        <div class="validating" id="validating">
          <span class="spinner"></span>
          <span id="validatingText">Scanning…</span>
        </div>

        <div class="error" id="errorBox" hidden></div>

        <div class="examples">
          <span>Try</span>
          <a href="#" data-host="github.com">github.com</a>
          <a href="#" data-host="cloudflare.com">cloudflare.com</a>
          <a href="#" data-host="bbc.com">bbc.com</a>
        </div>
      </section>

      <section class="recent" id="recent" hidden>
        <div class="recent-head">
          <h2>Recent public scans</h2>
          <a href="/api/v1/history" class="see-all">See all history →</a>
        </div>
        <div class="recent-grid" id="recentGrid"></div>
      </section>

      <section class="features">
        <div class="feature">
          <div class="ico">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"
              ><path d="M8 1.5l5.5 2.5v4c0 3.5-2.5 6-5.5 6.5-3-.5-5.5-3-5.5-6.5v-4L8 1.5z"></path>
              <path d="M5.5 8L7 9.5l3.5-3.5"></path>
            </svg>
          </div>
          <h3>Every protocol, every cipher</h3>
          <p>
            Enumerates TLS 1.0 through 1.3, plus SSLv2/SSLv3 via raw probes.
            Detects server vs client cipher preference and flags anything
            without forward secrecy or AEAD.
          </p>
        </div>
        <div class="feature">
          <div class="ico">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"
              ><rect x="2" y="3" width="12" height="10" rx="1.5"></rect>
              <path d="M2 6.5h12M5 9.5h3M5 11h5"></path>
            </svg>
          </div>
          <h3>Certificate chain + OCSP</h3>
          <p>
            Parses every certificate from leaf to root, validates the chain
            against the system root store, parses the stapled OCSP response
            and checks session resumption.
          </p>
        </div>
        <div class="feature">
          <div class="ico">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"
              ><path d="M8 2v6l4 2"></path><circle cx="8" cy="8" r="6.5"></circle>
            </svg>
          </div>
          <h3>Known weaknesses</h3>
          <p>
            Passive detection for POODLE, DROWN, BEAST, Sweet32, RC4,
            Heartbleed (Server-header heuristic), Lucky13 and Ticketbleed —
            each tied to a CVE.
          </p>
        </div>
        <div class="feature">
          <div class="ico">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"
              ><path d="M2 4h12M2 8h12M2 12h8"></path>
            </svg>
          </div>
          <h3>HTTP headers, graded</h3>
          <p>
            Independent A+ → F grade for HSTS, CSP, X-Frame-Options,
            X-Content-Type-Options, Referrer-Policy and Permissions-Policy —
            with bonus / malus for COOP, Server leaks and weak cookies.
          </p>
        </div>
        <div class="feature">
          <div class="ico">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"
              ><path d="M3 3h7l3 3v7H3z"></path><path d="M10 3v3h3"></path>
            </svg>
          </div>
          <h3>Custom checks</h3>
          <p>
            Looks for an RFC 9116 <code>security.txt</code> and inspects
            <code>robots.txt</code> for paths that leak the existence of
            sensitive admin or API routes.
          </p>
        </div>
        <div class="feature">
          <div class="ico">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"
              ><circle cx="5" cy="8" r="2.5"></circle><circle cx="11" cy="8" r="2.5"></circle>
              <path d="M5 5.5V3M11 5.5V3M5 10.5V13M11 10.5V13"></path>
            </svg>
          </div>
          <h3>Built for AI agents</h3>
          <p>
            Every finding is self-sufficient: title, impact and remediation
            inline. The full check catalog is served at
            <code>/api/v1/checks</code> for downstream agents and pipelines.
          </p>
        </div>
      </section>

      <section class="api">
        <div>
          <h2>The same scan, over JSON.</h2>
          <p>
            Pipe a hostname in, get a grade and a list of findings. Gate a CI
            build on a regression or feed the result to an AI agent.
          </p>
          <a href="/api/v1/checks" class="btn">Read the catalog →</a>
        </div>
        <pre class="codeblock"><span class="cmt"># scan a host and read the TLS grade</span>
<span class="kw">curl</span> <span class="str">-sS</span> http://localhost:8080/api/v1/scan \
  <span class="str">-H</span> <span class="str">"Content-Type: application/json"</span> \
  <span class="str">-d</span> <span class="str">{`{"host":"github.com"}`}</span> \
  | jq <span class="str">'.tls.grade'</span>
<span class="cmt"># → "A"</span></pre>
      </section>
    </main>

    <footer class="landing-footer">
      <div class="left">
        <svg class="brand-mark" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
          <circle cx="8" cy="8" r="6.5" fill="none" stroke="var(--good)" stroke-width="1.5" />
          <circle cx="8" cy="8" r="3.5" fill="var(--ink)" />
        </svg>
        websec0 · MIT
      </div>
      <nav>
        <a href="/api/v1/checks">Catalog</a>
        <a href="/api/v1/history">History</a>
        <a href="https://github.com/JoshuaMart/websec0">GitHub</a>
      </nav>
    </footer>

    <style>
      /* Landing-only layout. Design tokens come from global.css. */
      main { max-width: 1080px; margin: 0 auto; padding: 0 28px; }

      .hero {
        max-width: 760px; margin: 0 auto;
        padding: 36px 0 32px; text-align: center;
      }
      .eyebrow {
        display: inline-flex; align-items: center; gap: 8px;
        font-family: var(--font-mono); font-size: 11.5px; color: var(--muted);
        background: var(--card); border: 1px solid var(--line);
        padding: 5px 12px; border-radius: 999px;
        letter-spacing: 0.04em;
      }
      .eyebrow .dot {
        width: 6px; height: 6px; border-radius: 50%;
        background: var(--good);
        box-shadow: 0 0 0 3px var(--good-bg);
      }
      .hero h1 {
        margin: 22px 0 14px;
        font-family: var(--font-mono);
        font-size: 52px; line-height: 1.05;
        font-weight: 500; letter-spacing: -0.035em;
        color: var(--ink);
      }
      .hero h1 .accent { color: var(--good); }
      .hero p.lede {
        max-width: 600px; margin: 0 auto 32px;
        font-size: 16px; line-height: 1.55; color: var(--muted);
        text-wrap: pretty;
      }
      .scan-form {
        max-width: 600px; margin: 0 auto;
        background: var(--card); border: 1px solid var(--line-2);
        border-radius: 14px; padding: 6px;
        display: flex; align-items: center; gap: 6px;
        box-shadow: 0 1px 0 rgba(15,20,30,0.03), 0 16px 48px -16px rgba(15,20,30,0.18);
        transition: border-color .15s, box-shadow .15s;
      }
      .scan-form:focus-within {
        border-color: var(--ink-2);
        box-shadow: 0 1px 0 rgba(15,20,30,0.03), 0 16px 48px -16px rgba(15,20,30,0.28);
      }
      .scan-form .prefix {
        padding: 0 4px 0 14px;
        font-family: var(--font-mono); font-size: 14px; color: var(--muted-2);
      }
      .scan-form input {
        flex: 1; border: 0; outline: none; background: transparent;
        font-family: var(--font-mono); font-size: 15px;
        color: var(--ink); padding: 14px 4px;
      }
      .scan-form input::placeholder { color: var(--muted-2); }
      .scan-form .btn-primary { height: 44px; padding: 0 18px; font-size: 14px; border-radius: 9px; }

      .opt-public {
        display: inline-flex; align-items: center; gap: 8px;
        margin-top: 12px;
        font-size: 12px; color: var(--muted);
        font-family: var(--font-mono);
      }
      .opt-public input { accent-color: var(--ink); }

      .examples {
        margin-top: 20px; display: flex; flex-wrap: wrap; gap: 6px;
        justify-content: center; font-size: 12px; color: var(--muted);
        align-items: baseline;
      }
      .examples > span:first-child {
        font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.06em; font-size: 10.5px;
      }
      .examples a {
        text-decoration: none; font-family: var(--font-mono); font-size: 12px;
        color: var(--ink-2); border: 1px solid var(--line);
        padding: 3px 9px; border-radius: 6px; background: var(--card);
        transition: background .12s, border-color .12s;
      }
      .examples a:hover { background: var(--hover); border-color: var(--line-2); }

      .validating {
        text-align: center; margin-top: 14px;
        font-family: var(--font-mono); font-size: 12px; color: var(--muted);
        display: none;
      }
      .validating.on { display: block; }
      .validating .spinner {
        display: inline-block; width: 10px; height: 10px;
        border-radius: 50%; border: 1.5px solid var(--line-2);
        border-top-color: var(--ink); animation: spin .8s linear infinite;
        margin-right: 6px; vertical-align: -1px;
      }

      .error {
        max-width: 600px; margin: 14px auto 0;
        padding: 10px 14px; border-radius: 8px;
        background: var(--bad-bg); border: 1px solid var(--bad-line); color: var(--bad);
        font-family: var(--font-mono); font-size: 12px;
        text-align: center;
      }

      .recent { margin-top: 36px; }

      .features {
        margin-top: 80px;
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
      }
      .feature {
        background: var(--card); border: 1px solid var(--line);
        border-radius: var(--r-lg); padding: 22px;
      }
      .feature .ico {
        width: 28px; height: 28px; border-radius: 7px;
        background: var(--bg-sub); border: 1px solid var(--line);
        display: grid; place-items: center; color: var(--ink-2);
        margin-bottom: 14px;
      }
      .feature h3 { margin: 0 0 6px; font-size: 14px; font-weight: 600; }
      .feature p { margin: 0; font-size: 13px; color: var(--muted); line-height: 1.55; }
      .feature code { font-family: var(--font-mono); font-size: 12px; color: var(--ink-2); }

      .api {
        margin-top: 72px;
        display: grid; grid-template-columns: 1fr 1.2fr; gap: 28px; align-items: center;
      }
      .api h2 {
        font-family: var(--font-mono); font-size: 22px; font-weight: 500;
        letter-spacing: -0.02em; margin: 0 0 10px;
      }
      .api p { margin: 0 0 16px; font-size: 14px; color: var(--muted); line-height: 1.55; }
      .api .btn { height: 34px; }
      .api .codeblock { margin: 0; }

      .landing-footer {
        max-width: 1080px; margin: 80px auto 0; padding: 24px 28px 56px;
        border-top: 1px solid var(--line);
        display: flex; align-items: center; justify-content: space-between;
        font-size: 12px; color: var(--muted);
      }
      .landing-footer .left { font-family: var(--font-mono); display: flex; align-items: center; gap: 10px; }
      .landing-footer nav { display: flex; gap: 18px; }
      .landing-footer nav a { text-decoration: none; color: inherit; }
      .landing-footer nav a:hover { color: var(--ink-2); }

      @media (max-width: 880px) {
        .hero h1 { font-size: 38px; }
        .features { grid-template-columns: 1fr; }
        .api { grid-template-columns: 1fr; }
      }
    </style>

    <style is:global>
      /* Recent-scans strip — global so dynamic innerHTML cards pick up styles. */
      .recent-head {
        display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 14px;
      }
      .recent-head h2 {
        margin: 0; font-size: 12px; font-weight: 600;
        font-family: var(--font-mono); letter-spacing: 0.04em;
        text-transform: uppercase; color: var(--muted);
      }
      .recent-head .see-all {
        font-size: 12px; color: var(--muted); text-decoration: none;
      }
      .recent-head .see-all:hover { color: var(--ink-2); }

      .recent-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
      .recent-card {
        background: var(--card); border: 1px solid var(--line);
        border-radius: var(--r-md); padding: 12px 14px;
        display: flex; align-items: center; gap: 12px;
        text-decoration: none; color: inherit;
        transition: border-color .12s, transform .12s;
      }
      .recent-card:hover { border-color: var(--line-2); transform: translateY(-1px); }

      .recent-card .grades {
        display: flex; flex-direction: column; gap: 10px;
        flex-shrink: 0;
      }
      .recent-card .grade-row {
        display: flex; align-items: center; gap: 6px;
      }
      .recent-card .grade-tag {
        font-family: var(--font-mono); font-size: 9.5px; font-weight: 600;
        letter-spacing: 0.04em; color: var(--muted-2); text-transform: uppercase;
      }

      .grade-chip {
        width: 26px; height: 26px; border-radius: 50%;
        background: var(--ink); color: white;
        display: grid; place-items: center;
        font-family: var(--font-mono); font-weight: 600; font-size: 10.5px;
        flex-shrink: 0; position: relative;
      }
      .grade-chip::before {
        content: ""; position: absolute; inset: -3px;
        border-radius: 50%; border: 1.5px solid var(--good);
      }
      .grade-chip.warn::before { border-color: var(--warn); }
      .grade-chip.bad::before { border-color: var(--bad); }
      .grade-chip.unknown { background: var(--muted-2); }
      .grade-chip.unknown::before { border-color: var(--line-2); }

      .recent-card .meta { min-width: 0; flex: 1; }
      .recent-card .dom {
        font-family: var(--font-mono); font-size: 13px;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .recent-card .ago {
        font-size: 11.5px; color: var(--muted); margin-top: 4px;
        font-family: var(--font-mono);
      }

      @media (max-width: 880px) {
        .recent-grid { grid-template-columns: repeat(2, 1fr); }
      }
    </style>

    <script>
      // Form submit → POST /api/v1/scan → redirect to /r/{id} on success.
      const form = document.getElementById('scanForm') as HTMLFormElement;
      const input = document.getElementById('hostInput') as HTMLInputElement;
      const optPublic = document.getElementById('listInHistory') as HTMLInputElement;
      const validating = document.getElementById('validating') as HTMLDivElement;
      const validatingText = document.getElementById('validatingText') as HTMLSpanElement;
      const errorBox = document.getElementById('errorBox') as HTMLDivElement;

      function showError(msg: string) {
        errorBox.textContent = msg;
        errorBox.hidden = false;
        validating.classList.remove('on');
      }

      function startValidating(host: string) {
        errorBox.hidden = true;
        validatingText.textContent = `Scanning ${host} (up to 30 s)…`;
        validating.classList.add('on');
      }

      document.querySelectorAll<HTMLAnchorElement>('.examples a[data-host]').forEach((a) => {
        a.addEventListener('click', (e) => {
          e.preventDefault();
          input.value = a.dataset.host ?? '';
          input.focus();
        });
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const host = input.value.trim().replace(/^https?:\/\//i, '').replace(/\/$/, '');
        if (!host) return;
        startValidating(host);
        try {
          const resp = await fetch('/api/v1/scan', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ host, list_in_history: optPublic.checked }),
          });
          const data = await resp.json();
          if (!resp.ok) {
            showError(data.error?.message ?? `HTTP ${resp.status}`);
            return;
          }
          window.location.href = `/r/${data.id}`;
        } catch (err) {
          showError(err instanceof Error ? err.message : String(err));
        }
      });

      // Recent scans strip — populated lazily from /api/v1/history.
      type HistoryEntry = {
        id: string;
        host: string;
        scanned_at: string;
        tls_grade: string;
        headers_grade: string;
        highest_tls?: string;
      };

      function gradeRing(grade: string): string {
        if (!grade || grade === '?' || grade === 'T') return ' unknown';
        if (grade === 'A+' || grade === 'A') return '';
        if (grade === 'B' || grade === 'C') return ' warn';
        return ' bad';
      }

      function timeAgo(iso: string): string {
        const ms = Date.now() - new Date(iso).getTime();
        const s = Math.max(0, Math.floor(ms / 1000));
        if (s < 60) return `${s}s ago`;
        const m = Math.floor(s / 60);
        if (m < 60) return `${m}m ago`;
        const h = Math.floor(m / 60);
        if (h < 24) return `${h}h ago`;
        return `${Math.floor(h / 24)}d ago`;
      }

      function renderRecent(entries: HistoryEntry[]) {
        const grid = document.getElementById('recentGrid') as HTMLDivElement;
        const section = document.getElementById('recent') as HTMLElement;
        if (!entries.length) {
          section.hidden = true;
          return;
        }
        grid.innerHTML = entries
          .map((e) => {
            const tls = e.tls_grade || '?';
            const hdr = e.headers_grade || '?';
            const subtitle = e.highest_tls
              ? `${timeAgo(e.scanned_at)} · ${e.highest_tls}`
              : timeAgo(e.scanned_at);
            return `
              <a class="recent-card" href="/r/${encodeURIComponent(e.id)}">
                <div class="grades">
                  <div class="grade-row">
                    <span class="grade-chip${gradeRing(tls)}">${tls}</span>
                    <span class="grade-tag">TLS</span>
                  </div>
                  <div class="grade-row">
                    <span class="grade-chip${gradeRing(hdr)}">${hdr}</span>
                    <span class="grade-tag">HDR</span>
                  </div>
                </div>
                <div class="meta">
                  <div class="dom">${e.host}</div>
                  <div class="ago">${subtitle}</div>
                </div>
              </a>`;
          })
          .join('');
        section.hidden = false;
      }

      fetch('/api/v1/history?limit=4')
        .then((r) => (r.ok ? r.json() : []))
        .then((entries: HistoryEntry[]) => renderRecent(entries ?? []))
        .catch(() => {
          /* swallow — empty strip is fine */
        });
    </script>
  </body>
</html>
