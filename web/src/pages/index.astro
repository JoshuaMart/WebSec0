---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import ScanForm from '../components/ScanForm.astro';

const stats = [
  { value: '70+',  label: 'checks'            },
  { value: '9',    label: 'stacks'             },
  { value: '<8s',  label: 'median scan'        },
  { value: '0kB',  label: 'dependencies'       },
];

const mockFindings = [
  { id: 'TLS 1.3 + strong ciphers',    family: 'tls',     status: 'pass',   severity: null },
  { id: 'HSTS preload',                family: 'headers', status: 'pass',   severity: null },
  { id: 'Content-Security-Policy',     family: 'headers', status: 'fail',   severity: 'high',   label: 'MISSING' },
  { id: 'DNSSEC',                      family: 'dns',     status: 'pass',   severity: null },
  { id: 'CAA records',                 family: 'dns',     status: 'pass',   severity: null },
  { id: 'SPF + DMARC quarantine',      family: 'email',   status: 'warn',   severity: 'medium', label: 'WEAK' },
];

const features = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="w-4 h-4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
    </svg>`,
    title: 'Quick wins first',
    body: 'No 50-page reports. Findings are ranked by impact/effort ratio — fix what matters most without drowning in noise.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="w-4 h-4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/>
    </svg>`,
    title: 'Stack-specific fixes',
    body: 'Stop Googling. Get exact config snippets for nginx, Apache, Caddy, HAProxy, Cloudflare, Spring Boot, and IIS.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="w-4 h-4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"/>
    </svg>`,
    title: '4 tools in 1',
    body: 'Replaces SSL Labs, Hardenize, and SecurityHeaders.com. One self-hosted binary, no account, no telemetry.',
  },
];
---
<Base>
  <Nav />

  <main class="flex-1">

    <!-- ── Hero (split) ──────────────────────────────────────── -->
    <section class="pt-14 pb-10 px-6">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- Left: copy + form -->
        <div>
          <!-- GitHub badge -->
          <a
            href="https://github.com/JoshuaMart/websec0"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-sand-100 border border-sand-200
                   text-ink-muted text-xs font-mono font-medium mb-7 hover:border-sand-300 transition-colors"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            Open-source · MIT · Self-hostable
          </a>

          <!-- Headline -->
          <h1 class="text-4xl sm:text-5xl font-bold text-ink leading-tight tracking-tight mb-5">
            The web security scanner<br/>that goes straight<br/>
            <span class="text-accent">to the fix.</span>
          </h1>

          <!-- Subtitle -->
          <p class="text-lg text-ink-muted mb-8 leading-relaxed max-w-md">
            Replace SSL Labs, Hardenize, and SecurityHeaders.com with one lightweight tool.
            Get copy-paste remediation snippets for your exact stack.
          </p>

          <!-- Scan form -->
          <ScanForm />

          <!-- Trust points -->
          <div class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-1.5">
            {[
              'No sign-up required',
              'Open source',
              'Actionable results',
            ].map((label) => (
              <span class="flex items-center gap-1.5 text-xs font-mono text-ink-muted">
                <svg class="w-3.5 h-3.5 text-green-500 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
                </svg>
                {label}
              </span>
            ))}
          </div>
        </div>

        <!-- Right: mock report preview -->
        <div class="hidden lg:block">
          <div class="bg-white border border-sand-200 rounded-2xl overflow-hidden shadow-[0_4px_24px_rgba(17,24,39,0.07)]">

            <!-- Report top bar -->
            <div class="flex items-center justify-between px-4 py-3 border-b border-sand-200 bg-sand-50">
              <div class="flex items-center gap-2">
                <div class="flex gap-1.5" aria-hidden="true">
                  <div class="w-2.5 h-2.5 rounded-full bg-sand-300"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-sand-300"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-sand-300"></div>
                </div>
                <span class="font-mono text-xs text-ink-faint">example.com</span>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                <span class="font-mono text-xs text-green-600">completed · 6s</span>
              </div>
            </div>

            <!-- Grade row -->
            <div class="flex items-center gap-4 px-4 py-4 border-b border-sand-200">
              <div class="w-14 h-14 rounded-xl border-2 flex items-center justify-center flex-shrink-0"
                   style="background:#dbf3db; border-color:#b8e8b9;">
                <span class="text-2xl font-bold font-mono" style="color:#4e9a52;">B+</span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-baseline gap-1 mb-1.5">
                  <span class="text-xl font-bold font-mono text-ink">82</span>
                  <span class="text-xs font-mono text-ink-faint">/ 100</span>
                  <span class="ml-auto text-xs font-mono text-accent">7 quick wins</span>
                </div>
                <div class="h-1.5 bg-sand-200 rounded-full overflow-hidden">
                  <div class="h-full w-[82%] rounded-full" style="background:#4e9a52;"></div>
                </div>
              </div>
            </div>

            <!-- Findings list -->
            <div class="divide-y divide-sand-200">
              {mockFindings.map(({ id, family, status, severity, label }) => (
                <div class="flex items-center gap-3 px-4 py-2.5">
                  <span
                    class:list={[
                      'font-mono text-xs w-3 text-center flex-shrink-0',
                      status === 'pass' ? 'text-green-600' :
                      severity === 'high' ? 'text-orange-600' : 'text-amber-600'
                    ]}
                    aria-hidden="true"
                  >
                    {status === 'pass' ? '✓' : '✕'}
                  </span>
                  <span class="font-mono text-xs text-ink flex-1 min-w-0 truncate">{id}</span>
                  <span class="font-mono text-[10px] text-ink-faint uppercase">{family}</span>
                  {label && (
                    <span
                      class:list={[
                        'badge text-[10px]',
                        severity === 'high' ? 'severity-high' : 'severity-medium'
                      ]}
                    >
                      {label}
                    </span>
                  )}
                  {!label && (
                    <span class="font-mono text-[10px] text-green-600">PASS</span>
                  )}
                </div>
              ))}
            </div>

            <!-- Footer -->
            <div class="px-4 py-3 border-t border-sand-200 bg-sand-50 flex items-center justify-between">
              <span class="font-mono text-xs text-ink-faint">Showing 6 of 18 total checks</span>
              <span class="font-mono text-xs text-accent">See full report →</span>
            </div>

          </div>
        </div>

      </div>
    </section>

    <!-- ── Stats row ─────────────────────────────────────────── -->
    <section class="py-5 border-y border-sand-200 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <dl class="flex flex-wrap items-center justify-center gap-x-12 gap-y-4">
          {stats.map(({ value, label }) => (
            <div class="text-center">
              <dt class="text-2xl font-bold font-mono text-ink">{value}</dt>
              <dd class="text-xs font-mono text-ink-muted mt-0.5">{label}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- ── Features ──────────────────────────────────────────── -->
    <section class="py-16 px-6">
      <div class="max-w-6xl mx-auto grid sm:grid-cols-3 gap-10">
        {features.map(({ icon, title, body }) => (
          <div class="flex flex-col gap-3">
            <div
              class="w-8 h-8 rounded-lg bg-accent-light border border-accent-border text-accent
                     flex items-center justify-center flex-shrink-0"
              set:html={icon}
            />
            <h2 class="text-sm font-semibold text-ink">{title}</h2>
            <p class="text-sm text-ink-muted leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ── "Stop running four scanners" CTA ──────────────────── -->
    <section class="py-20 px-6 bg-ink text-white">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-bold leading-tight mb-4">
          Stop running four scanners.<br/>Start fixing things.
        </h2>
        <p class="text-gray-400 mb-8 text-base leading-relaxed">
          Free, open-source, AGPL-3.0. Runs anywhere Go runs. No account,
          no telemetry, no upsell.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a
            href="/"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent text-white text-sm font-medium
                   hover:bg-accent-hover transition-colors"
          >
            <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M2 10a8 8 0 1116 0 8 8 0 01-16 0zm6.39-2.908a.75.75 0 01.766.027l3.5 2.25a.75.75 0 010 1.262l-3.5 2.25A.75.75 0 018 12.25v-4.5a.75.75 0 01.39-.658z" clip-rule="evenodd"/>
            </svg>
            Run your first scan
          </a>
          <a
            href="https://github.com/JoshuaMart/websec0"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-gray-600 text-gray-300 text-sm font-mono
                   hover:border-gray-400 hover:text-white transition-colors"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            View source
          </a>
        </div>
      </div>
    </section>

    <!-- ── Passive scanner note ──────────────────────────────── -->
    <section class="py-8 px-6 bg-white border-t border-sand-200">
      <div class="max-w-2xl mx-auto flex items-start gap-3">
        <div class="w-5 h-5 rounded bg-blue-50 border border-blue-200 flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-3 h-3 text-blue-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd"/>
          </svg>
        </div>
        <p class="text-sm text-ink-muted leading-relaxed">
          <span class="font-medium text-ink">Passive scanner.</span>{' '}
          WebSec0 performs standard HTTP/TLS requests and DNS lookups only —
          no crawling, no fuzzing, no exploit attempts. Under 50 requests per scan.{' '}
          <a href="/about/" class="text-accent hover:underline font-mono text-xs">learn more →</a>
        </p>
      </div>
    </section>

  </main>

  <!-- ── Footer ────────────────────────────────────────────── -->
  <footer class="py-7 px-6 border-t border-sand-200 bg-white">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="font-mono text-xs text-ink-faint">WebSec0 · MIT License</span>
      <nav class="flex items-center gap-5" aria-label="Footer">
        {[
          { href: '/checks/',       label: 'Checks'  },
          { href: '/about/',        label: 'About'   },
          { href: '/docs/api/',     label: 'API'     },
          { href: '/legal/tos/',    label: 'Terms'   },
          { href: '/legal/privacy/', label: 'Privacy' },
        ].map(({ href, label }) => (
          <a href={href} class="font-mono text-xs text-ink-faint hover:text-ink transition-colors">
            {label}
          </a>
        ))}
      </nav>
    </div>
  </footer>

</Base>
