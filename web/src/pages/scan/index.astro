---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
---
<Base title="Scan Report">
  <Nav />

  <main
    x-data="scanPage"
    x-cloak
    class="max-w-5xl mx-auto px-6 py-10 min-h-[60vh]"
  >

    <!-- ── Loading ────────────────────────────────────────────── -->
    <div x-show="status === 'loading'" class="flex items-center justify-center py-32">
      <svg class="w-6 h-6 animate-spin text-ink-faint" viewBox="0 0 24 24" fill="none">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"/>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
      </svg>
    </div>

    <!-- ── Not found ──────────────────────────────────────────── -->
    <div x-show="status === 'not_found'" class="text-center py-32">
      <p class="font-mono text-sm text-ink-faint mb-1">scan not found or expired</p>
      <p class="font-mono text-xs text-ink-faint mb-6" x-text="guid"></p>
      <a href="/" class="text-sm text-accent hover:underline font-mono">← Start a new scan</a>
    </div>

    <!-- ── Failed ─────────────────────────────────────────────── -->
    <div x-show="status === 'failed'" class="text-center py-32">
      <p class="font-mono text-sm text-red-600 mb-4" x-text="error || 'Scan failed.'"></p>
      <button @click="fetchScan()" class="text-sm text-accent hover:underline font-mono">Retry</button>
    </div>

    <!-- ── Active (queued / running / completed) ──────────────── -->
    <div x-show="['queued','running','completed'].includes(status)">

      <!-- Page header: target + status + export buttons -->
      <div class="flex items-start justify-between gap-4 mb-8">
        <div>
          <div class="flex items-center gap-2 mb-1.5 text-xs font-mono">
            <!-- Running dot -->
            <span x-show="status === 'running'" class="flex items-center gap-1.5 text-ink-faint">
              <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
              scanning
            </span>
            <span x-show="status === 'queued'" class="text-ink-faint">queued…</span>
            <span x-show="status === 'completed'" class="text-green-600 flex items-center gap-1">
              <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
              </svg>
              completed
            </span>
            <!-- Duration -->
            <span
              x-show="status === 'completed' && duration"
              class="text-ink-faint"
              x-text="'· ' + duration"
            ></span>
          </div>
          <h1 class="text-xl font-semibold font-mono text-ink tracking-tight" x-text="target || '…'"></h1>
        </div>

        <!-- Export buttons -->
        <div x-show="status === 'completed'" class="flex items-center gap-2 flex-shrink-0">
          <a
            :href="links.markdown"
            download
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-sand-200 text-xs font-mono
                   text-ink-muted hover:text-ink hover:border-sand-300 transition-colors"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M10.75 2.75a.75.75 0 00-1.5 0v8.614L6.295 8.235a.75.75 0 10-1.09 1.03l4.25 4.5a.75.75 0 001.09 0l4.25-4.5a.75.75 0 00-1.09-1.03l-2.955 3.129V2.75z"/>
              <path d="M3.5 12.75a.75.75 0 00-1.5 0v2.5A2.75 2.75 0 004.75 18h10.5A2.75 2.75 0 0018 15.25v-2.5a.75.75 0 00-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5z"/>
            </svg>
            Markdown
          </a>
          <a
            :href="links.sarif"
            download
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-sand-200 text-xs font-mono
                   text-ink-muted hover:text-ink hover:border-sand-300 transition-colors"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M4.5 2A1.5 1.5 0 003 3.5v13A1.5 1.5 0 004.5 18h11a1.5 1.5 0 001.5-1.5V7.621a1.5 1.5 0 00-.44-1.06l-4.12-4.122A1.5 1.5 0 0011.378 2H4.5zm2.25 8.5a.75.75 0 000 1.5h6.5a.75.75 0 000-1.5h-6.5zm0 3a.75.75 0 000 1.5h6.5a.75.75 0 000-1.5h-6.5zm0-6a.75.75 0 000 1.5h3a.75.75 0 000-1.5h-3z" clip-rule="evenodd"/>
            </svg>
            SARIF
          </a>
        </div>
      </div>

      <!-- ── Progress bar (queued / running) ────────────────── -->
      <div x-show="status === 'queued' || status === 'running'" class="mb-10">
        <div class="h-1 bg-sand-200 rounded-full overflow-hidden mb-2.5">
          <div
            class="h-full bg-accent rounded-full transition-all duration-500"
            :style="'width:' + progressPercent + '%'"
          ></div>
        </div>
        <div class="flex items-center justify-between text-xs font-mono text-ink-faint">
          <span x-text="progress.current_phase ? 'checking ' + progress.current_phase : 'starting…'"></span>
          <span x-text="progress.completed + ' / ' + progress.total"></span>
        </div>

        <!-- Live findings feed -->
        <div x-show="liveFindings.length > 0" class="mt-6 space-y-1.5" role="log" aria-live="polite" aria-label="Live findings">
          <template x-for="f in liveFindings.slice(0, 25)" :key="f.id">
            <div
              class="flex items-center gap-3 py-2 px-3 rounded-lg bg-white border border-sand-200"
              x-transition:enter="transition ease-out duration-150"
              x-transition:enter-start="opacity-0 -translate-y-1"
              x-transition:enter-end="opacity-100 translate-y-0"
            >
              <span
                class="font-mono text-xs w-4 text-center flex-shrink-0"
                :class="statusIconClass(f.status, f.severity)"
                x-text="statusIcon(f.status)"
                aria-hidden="true"
              ></span>
              <span class="font-mono text-xs text-ink flex-1 truncate" x-text="f.id"></span>
              <span class="font-mono text-xs text-ink-faint" x-text="f.family"></span>
              <span
                class="badge flex-shrink-0"
                :class="'severity-' + (f.severity || 'info')"
                x-show="f.status !== 'pass'"
                x-text="f.severity"
              ></span>
              <span class="font-mono text-xs text-green-600 flex-shrink-0" x-show="f.status === 'pass'">pass</span>
            </div>
          </template>
        </div>
      </div>

      <!-- ── Grade header (completed) ────────────────────────── -->
      <div x-show="status === 'completed'" class="mb-10">
        <div class="flex items-start gap-5 p-6 bg-white border border-sand-200 rounded-xl">

          <!-- Grade letter -->
          <div
            class="w-20 h-20 rounded-xl border-2 flex items-center justify-center flex-shrink-0"
            :class="gradeBgClass(grade)"
            aria-label="Grade"
          >
            <span
              class="text-4xl font-bold font-mono"
              :class="gradeColorClass(grade)"
              x-text="grade || '?'"
            ></span>
          </div>

          <!-- Score + counts -->
          <div class="flex-1 min-w-0 pt-1">
            <div class="flex items-baseline gap-1.5 mb-3">
              <span class="text-3xl font-bold font-mono text-ink" x-text="score"></span>
              <span class="text-sm font-mono text-ink-faint">/ 100</span>
            </div>
            <!-- Score bar -->
            <div class="h-1.5 bg-sand-200 rounded-full overflow-hidden mb-4">
              <div
                class="h-full rounded-full transition-all duration-700"
                :class="gradeBarClass(grade)"
                :style="'width:' + score + '%'"
              ></div>
            </div>
            <!-- Severity counts -->
            <div class="flex flex-wrap items-center gap-2">
              <template x-for="[sev, count] in severityCounts" :key="sev">
                <span class="badge" :class="'severity-' + sev" x-text="count + ' ' + sev" x-show="count > 0"></span>
              </template>
              <span class="font-mono text-xs text-green-600" x-show="counts.passed > 0" x-text="counts.passed + ' passed'"></span>
              <span class="font-mono text-xs text-ink-faint" x-show="counts.skipped > 0" x-text="counts.skipped + ' skipped'"></span>
            </div>
          </div>

        </div>
      </div>

      <!-- ── Quick wins (completed) ──────────────────────────── -->
      <div x-show="status === 'completed' && quickWinFindings.length > 0" class="mb-8">
        <div class="flex items-center gap-2 mb-3">
          <svg class="w-4 h-4 text-accent" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M11.983 1.907a.75.75 0 00-1.292-.657l-8.5 9.5A.75.75 0 002.75 12h6.572l-1.305 6.093a.75.75 0 001.292.657l8.5-9.5A.75.75 0 0017.25 8h-6.572l1.305-6.093z"/>
          </svg>
          <h2 class="text-sm font-semibold text-ink">Quick wins</h2>
          <span class="badge bg-accent-light text-accent border-accent-border font-mono" x-text="quickWinFindings.length"></span>
        </div>
        <div class="space-y-2">
          <template x-for="finding in quickWinFindings" :key="finding.id + '-qw'">
            <div x-data="findingCard(finding)" class="bg-white border border-sand-200 rounded-xl overflow-hidden">
              <div set:html=""></div>
            </div>
          </template>
        </div>
      </div>

      <!-- ── Other failures (completed) ─────────────────────── -->
      <div x-show="status === 'completed' && otherFailedFindings.length > 0" class="mb-8">
        <div class="flex items-center gap-2 mb-3">
          <h2 class="text-sm font-semibold text-ink">Findings</h2>
          <span
            class="badge bg-sand-100 text-ink-muted border-sand-200 font-mono"
            x-text="otherFailedFindings.length"
          ></span>
        </div>
        <div class="space-y-2">
          <template x-for="finding in otherFailedFindings" :key="finding.id + '-f'">
            <div x-data="findingCard(finding)" class="bg-white border border-sand-200 rounded-xl overflow-hidden">
            </div>
          </template>
        </div>
      </div>

      <!-- ── Passed checks (completed, collapsed) ────────────── -->
      <div x-show="status === 'completed' && passedFindings.length > 0" class="mb-8">
        <button
          @click="showPassed = !showPassed"
          class="flex items-center gap-2 text-sm text-ink-muted hover:text-ink transition-colors"
          type="button"
          :aria-expanded="showPassed"
        >
          <svg
            class="w-3.5 h-3.5 transition-transform duration-200 text-ink-faint"
            :class="showPassed ? 'rotate-90' : ''"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/>
          </svg>
          <span x-text="passedFindings.length + ' passed checks'"></span>
        </button>
        <div x-show="showPassed" x-transition class="mt-3 space-y-1">
          <template x-for="f in passedFindings" :key="f.id + '-p'">
            <div class="flex items-center gap-3 py-1.5 px-3 rounded-lg border border-sand-200">
              <span class="font-mono text-xs text-green-600 flex-shrink-0" aria-hidden="true">✓</span>
              <span class="font-mono text-xs text-ink flex-1 min-w-0 truncate" x-text="f.id"></span>
              <span class="font-mono text-xs text-ink-faint flex-shrink-0" x-text="f.family"></span>
            </div>
          </template>
        </div>
      </div>

    </div><!-- end active -->
  </main>
</Base>

<!-- ── Finding card template (rendered by Alpine inside x-for) ────────── -->
<template id="finding-card-tpl">
  <!-- header row -->
  <div
    @click="open = !open"
    class="flex items-start gap-3 p-4 cursor-pointer hover:bg-sand-50 transition-colors select-none"
    :aria-expanded="open"
    role="button"
    tabindex="0"
    @keydown.enter.prevent="open = !open"
    @keydown.space.prevent="open = !open"
  >
    <!-- Status icon -->
    <span
      class="font-mono text-sm mt-0.5 w-4 text-center flex-shrink-0"
      :class="iconClass"
      x-text="icon"
      aria-hidden="true"
    ></span>

    <!-- Title + description -->
    <div class="flex-1 min-w-0">
      <p class="font-mono text-sm font-medium text-ink leading-tight" x-text="finding.id"></p>
      <p class="text-xs text-ink-muted mt-0.5 leading-snug" x-text="finding.title || finding.description || ''"></p>
    </div>

    <!-- Badges + chevron -->
    <div class="flex items-center gap-2 flex-shrink-0 ml-2">
      <span class="badge" :class="'severity-' + finding.severity" x-text="finding.severity"></span>
      <span class="badge bg-sand-100 text-ink-muted border-sand-200" x-text="finding.family"></span>
      <svg
        class="w-4 h-4 text-ink-faint transition-transform duration-200 flex-shrink-0"
        :class="open ? 'rotate-180' : ''"
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
      >
        <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/>
      </svg>
    </div>
  </div>

  <!-- Expanded body -->
  <div x-show="open" x-transition class="border-t border-sand-200 bg-sand-50 px-5 pb-5 pt-4 space-y-4">

    <!-- Description (if title already shown above) -->
    <p
      x-show="finding.title && finding.description"
      class="text-sm text-ink-muted leading-relaxed"
      x-text="finding.description"
    ></p>

    <!-- Evidence -->
    <div x-show="hasEvidence">
      <p class="text-xs font-mono text-ink-faint uppercase tracking-wider mb-2">Evidence</p>
      <pre
        class="text-xs font-mono text-ink-muted bg-white border border-sand-200 rounded-lg p-3 overflow-x-auto whitespace-pre-wrap break-all"
        x-text="evidenceText"
      ></pre>
    </div>

    <!-- Remediation snippets -->
    <div x-show="stacks.length > 0">
      <p class="text-xs font-mono text-ink-faint uppercase tracking-wider mb-2">Fix for</p>

      <!-- Stack tabs -->
      <div class="flex flex-wrap gap-1 mb-3">
        <template x-for="s in stacks" :key="s">
          <button
            @click="tab = s"
            :class="tab === s ? 'tab-btn tab-btn-active' : 'tab-btn'"
            type="button"
            x-text="s"
          ></button>
        </template>
      </div>

      <!-- Code block -->
      <div class="relative bg-gray-950 rounded-lg px-4 pt-3 pb-4">
        <div class="flex gap-1.5 mb-2.5" aria-hidden="true">
          <div class="w-2 h-2 rounded-full bg-gray-700"></div>
          <div class="w-2 h-2 rounded-full bg-gray-700"></div>
          <div class="w-2 h-2 rounded-full bg-gray-700"></div>
        </div>
        <pre
          class="font-mono text-sm text-green-400 leading-relaxed whitespace-pre-wrap break-all pr-16"
          x-text="currentSnippet"
          aria-label="Configuration snippet"
        ></pre>

        <!-- Copy button -->
        <button
          x-data="{ copied: false }"
          @click="navigator.clipboard.writeText(currentSnippet).then(() => { copied = true; setTimeout(() => { copied = false }, 2000) }).catch(() => {})"
          type="button"
          class="absolute top-3 right-3 flex items-center gap-1.5 px-2.5 py-1 rounded-md
                 text-xs font-mono font-medium transition-all
                 bg-gray-800 text-gray-400 hover:bg-gray-700 hover:text-gray-200"
        >
          <svg x-show="!copied" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M7 3.5A1.5 1.5 0 018.5 2h3.879a1.5 1.5 0 011.06.44l3.122 3.12A1.5 1.5 0 0117 6.622V12.5a1.5 1.5 0 01-1.5 1.5h-1v-3.379a3 3 0 00-.879-2.121L10.5 5.379A3 3 0 008.379 4.5H7v-1z"/>
            <path d="M4.5 6A1.5 1.5 0 003 7.5v9A1.5 1.5 0 004.5 18h7a1.5 1.5 0 001.5-1.5v-5.879a1.5 1.5 0 00-.44-1.06L9.44 6.439A1.5 1.5 0 008.378 6H4.5z"/>
          </svg>
          <svg x-show="copied" class="w-3.5 h-3.5 text-green-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
          </svg>
          <span x-text="copied ? 'Copied!' : 'Copy'"></span>
        </button>
      </div>

      <!-- Verify command -->
      <p
        x-show="verifyCmd"
        class="mt-2 text-xs font-mono text-ink-faint"
        x-text="'verify: ' + verifyCmd"
      ></p>
    </div>

    <!-- No snippets fallback -->
    <div x-show="stacks.length === 0 && finding.status !== 'pass'">
      <p class="text-xs text-ink-faint">
        No stack-specific snippets yet for this check.
        <a href="/checks/" class="text-accent hover:underline">View check catalog →</a>
      </p>
    </div>

  </div>
</template>

<script>
  document.addEventListener('alpine:init', () => {

    // ── Finding card component (used inside x-for) ────────────
    Alpine.data('findingCard', (finding) => ({
      finding,
      open: false,
      tab: '',

      init() {
        const stacks = this.stacks;
        this.tab = stacks[0] || '';

        // Clone and mount the template
        const tpl = document.getElementById('finding-card-tpl');
        if (tpl) {
          const clone = tpl.content.cloneNode(true);
          this.$el.appendChild(clone);
        }
      },

      get icon() {
        if (this.finding.status === 'pass') return '✓';
        if (this.finding.status === 'fail' || this.finding.status === 'warn') return '✕';
        return '—';
      },

      get iconClass() {
        const s = this.finding.status;
        const sev = this.finding.severity;
        if (s === 'pass') return 'text-green-600';
        if (s === 'fail' || s === 'warn') {
          if (sev === 'critical') return 'text-red-600';
          if (sev === 'high') return 'text-orange-600';
          if (sev === 'medium') return 'text-amber-600';
          return 'text-blue-600';
        }
        return 'text-ink-faint';
      },

      get stacks() {
        const snippets = this.finding.remediation && this.finding.remediation.snippets;
        if (!snippets || typeof snippets !== 'object') return [];
        return Object.keys(snippets);
      },

      get currentSnippet() {
        const snippets = this.finding.remediation && this.finding.remediation.snippets;
        if (!snippets) return '';
        return snippets[this.tab] || '';
      },

      get verifyCmd() {
        return (this.finding.remediation && this.finding.remediation.verification) || '';
      },

      get hasEvidence() {
        const ev = this.finding.evidence;
        return ev && typeof ev === 'object' && Object.keys(ev).length > 0;
      },

      get evidenceText() {
        try {
          return JSON.stringify(this.finding.evidence, null, 2);
        } catch {
          return String(this.finding.evidence);
        }
      },
    }));

    // ── Main scan page ────────────────────────────────────────
    Alpine.data('scanPage', () => ({
      // State
      guid: null,
      status: 'loading',
      error: '',

      // Metadata
      target: '',
      startedAt: null,
      completedAt: null,
      links: { markdown: '#', sarif: '#' },

      // Grade + score
      grade: '',
      score: 0,

      // Findings
      findings: [],
      liveFindings: [],
      counts: { critical: 0, high: 0, medium: 0, low: 0, info: 0, passed: 0, skipped: 0, errored: 0 },

      // Progress (running)
      progress: { total: 70, completed: 0, current_phase: '' },

      // SSE
      eventSource: null,

      // UI
      showPassed: false,

      // ── Lifecycle ──────────────────────────────────────────
      async init() {
        const parts = window.location.pathname.split('/').filter(p => p.length > 0);
        // pathname: /scan/{guid}/ → ['scan', 'guid']
        this.guid = parts[1] || null;

        if (!this.guid) {
          this.status = 'not_found';
          return;
        }

        await this.fetchScan();
      },

      destroy() {
        this.closeSSE();
      },

      // ── Data fetching ──────────────────────────────────────
      async fetchScan() {
        try {
          const res = await fetch('/api/v1/scans/' + this.guid);
          if (res.status === 404) { this.status = 'not_found'; return; }
          if (!res.ok) { this.status = 'failed'; this.error = 'Server error ' + res.status; return; }
          const data = await res.json();
          this.applyData(data);
          if (data.status === 'running' || data.status === 'queued') {
            this.connectSSE();
          }
        } catch {
          this.status = 'failed';
          this.error = 'Network error. Check your connection.';
        }
      },

      applyData(data) {
        this.status = data.status || 'failed';
        this.target = data.target || '';
        this.startedAt = data.started_at || null;
        this.completedAt = data.completed_at || null;

        if (data.links) {
          this.links = {
            markdown: data.links.markdown || ('/api/v1/scans/' + this.guid + '/markdown'),
            sarif:    data.links.sarif    || ('/api/v1/scans/' + this.guid + '/sarif'),
          };
        }
        if (data.progress) {
          this.progress = { ...this.progress, ...data.progress };
        }
        if (typeof data.grade === 'string') this.grade = data.grade;
        if (typeof data.score === 'number') this.score = data.score;

        if (Array.isArray(data.findings)) {
          this.findings = data.findings;
          // Recompute counts from findings
          this.counts = { critical:0, high:0, medium:0, low:0, info:0, passed:0, skipped:0, errored:0 };
          for (const f of data.findings) {
            if (f.status === 'pass') this.counts.passed++;
            else if (f.status === 'skipped') this.counts.skipped++;
            else if (f.status === 'error') this.counts.errored++;
            else if (f.severity in this.counts) this.counts[f.severity]++;
          }
        }
      },

      // ── SSE ───────────────────────────────────────────────
      connectSSE() {
        if (this.eventSource) return;
        this.eventSource = new EventSource('/api/v1/scans/' + this.guid + '/events');

        this.eventSource.addEventListener('progress', e => {
          try { this.progress = { ...this.progress, ...JSON.parse(e.data) }; } catch {}
        });

        this.eventSource.addEventListener('finding', e => {
          try {
            const f = JSON.parse(e.data);
            this.liveFindings = [f, ...this.liveFindings];
          } catch {}
        });

        this.eventSource.addEventListener('completed', () => {
          this.closeSSE();
          this.fetchScan();
        });

        this.eventSource.addEventListener('failed', e => {
          this.closeSSE();
          try {
            const d = JSON.parse(e.data);
            this.error = d.error || 'Scan failed';
          } catch {}
          this.status = 'failed';
        });

        this.eventSource.onerror = () => {
          setTimeout(() => {
            if (this.status !== 'completed' && this.status !== 'failed') {
              this.fetchScan();
            }
          }, 3000);
        };
      },

      closeSSE() {
        if (this.eventSource) {
          this.eventSource.close();
          this.eventSource = null;
        }
      },

      // ── Computed ──────────────────────────────────────────
      get progressPercent() {
        if (!this.progress.total) return 0;
        return Math.min(100, Math.round((this.progress.completed / this.progress.total) * 100));
      },

      get failedFindings() {
        return this.findings.filter(f => f.status === 'fail' || f.status === 'warn');
      },

      get passedFindings() {
        return this.findings.filter(f => f.status === 'pass');
      },

      get quickWinFindings() {
        return this.failedFindings.filter(f =>
          f.severity === 'critical' || f.severity === 'high' || f.severity === 'medium'
        );
      },

      get otherFailedFindings() {
        const qwIds = new Set(this.quickWinFindings.map(f => f.id));
        return this.failedFindings.filter(f => !qwIds.has(f.id));
      },

      get severityCounts() {
        return [
          ['critical', this.counts.critical],
          ['high',     this.counts.high],
          ['medium',   this.counts.medium],
          ['low',      this.counts.low],
          ['info',     this.counts.info],
        ];
      },

      get duration() {
        if (!this.startedAt || !this.completedAt) return '';
        const ms = new Date(this.completedAt) - new Date(this.startedAt);
        return Math.round(ms / 1000) + 's';
      },

      // ── Helpers ───────────────────────────────────────────
      gradeColorClass(g) {
        if (!g) return 'text-ink-faint';
        const c = g.charAt(0);
        if (c === 'A') return 'text-green-600';
        if (c === 'B') return 'text-blue-600';
        if (c === 'C') return 'text-amber-600';
        return 'text-red-600';
      },

      gradeBgClass(g) {
        if (!g) return 'bg-sand-100 border-sand-200';
        const c = g.charAt(0);
        if (c === 'A') return 'bg-green-50 border-green-200';
        if (c === 'B') return 'bg-blue-50 border-blue-200';
        if (c === 'C') return 'bg-amber-50 border-amber-200';
        return 'bg-red-50 border-red-200';
      },

      gradeBarClass(g) {
        if (!g) return 'bg-sand-300';
        const c = g.charAt(0);
        if (c === 'A') return 'bg-green-500';
        if (c === 'B') return 'bg-blue-500';
        if (c === 'C') return 'bg-amber-500';
        return 'bg-red-500';
      },

      statusIcon(status) {
        if (status === 'pass') return '✓';
        if (status === 'fail' || status === 'warn') return '✕';
        return '—';
      },

      statusIconClass(status, severity) {
        if (status === 'pass') return 'text-green-600';
        if (status === 'fail' || status === 'warn') {
          if (severity === 'critical') return 'text-red-600';
          if (severity === 'high') return 'text-orange-600';
          if (severity === 'medium') return 'text-amber-600';
          return 'text-blue-600';
        }
        return 'text-ink-faint';
      },
    }));
  });
</script>
